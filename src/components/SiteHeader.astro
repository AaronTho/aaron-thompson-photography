---
import { site, nav } from "../lib/site.ts";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string) {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<header class="border-b border-stone-200/70">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6 sm:px-8 lg:px-12">
    <a
      href="/"
      class="font-display text-lg font-light tracking-tight text-stone-900 transition-opacity hover:opacity-70 sm:text-xl lg:text-2xl"
    >
      {site.short}
    </a>
    <nav aria-label="Primary">
      <ul class="flex items-center gap-6 text-[0.78rem] uppercase tracking-[0.18em] text-stone-500 sm:gap-9">
        {
          nav
            .filter((item) => item.href !== "/")
            .map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "transition-colors hover:text-stone-900",
                    isActive(item.href) && "text-stone-900",
                  ]}
                  aria-current={isActive(item.href) ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
        }
      </ul>
    </nav>
  </div>
</header>
