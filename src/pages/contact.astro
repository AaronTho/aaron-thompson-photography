---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../lib/site.ts";
---

<BaseLayout title="Contact" narrow>
  <section class="mx-auto max-w-2xl px-6 pt-16 pb-24 sm:px-8 sm:pt-24">
    <p class="text-xs uppercase tracking-[0.22em] text-stone-500">Contact</p>
    <h1 class="mt-4 font-display text-4xl font-light leading-tight text-stone-900 sm:text-5xl">
      Let’s plan something.
    </h1>
    <p class="mt-6 text-base leading-relaxed text-stone-600 sm:text-lg">
      Tell me a little about what you have in mind — a session, an event, a project, a
      maybe-someday idea. I’ll get back to you within a day or two.
    </p>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      action="/thank-you"
      class="mt-12 space-y-6"
    >
      {/* Netlify form metadata */}
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden">
        <label>
          Don’t fill this out if you’re human:
          <input name="bot-field" />
        </label>
      </p>

      <div>
        <label for="name" class="block text-xs uppercase tracking-[0.18em] text-stone-500">Name</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          autocomplete="name"
          class="mt-2 block w-full border-0 border-b border-stone-300 bg-transparent px-0 py-2 text-stone-900 placeholder-stone-400 focus:border-stone-900 focus:outline-none focus:ring-0"
        />
      </div>

      <div>
        <label for="email" class="block text-xs uppercase tracking-[0.18em] text-stone-500">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="mt-2 block w-full border-0 border-b border-stone-300 bg-transparent px-0 py-2 text-stone-900 placeholder-stone-400 focus:border-stone-900 focus:outline-none focus:ring-0"
        />
      </div>

      <div>
        <label for="phone" class="block text-xs uppercase tracking-[0.18em] text-stone-500">
          Phone <span class="normal-case tracking-normal text-stone-400">(optional)</span>
        </label>
        <input
          id="phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          class="mt-2 block w-full border-0 border-b border-stone-300 bg-transparent px-0 py-2 text-stone-900 placeholder-stone-400 focus:border-stone-900 focus:outline-none focus:ring-0"
        />
      </div>

      <div>
        <label for="subject" class="block text-xs uppercase tracking-[0.18em] text-stone-500">
          What’s the occasion?
        </label>
        <select
          id="subject"
          name="subject"
          class="mt-2 block w-full appearance-none border-0 border-b border-stone-300 bg-transparent px-0 py-2 text-stone-900 focus:border-stone-900 focus:outline-none focus:ring-0"
        >
          <option value="">Select one…</option>
          <option>Family / portrait session</option>
          <option>Senior portraits</option>
          <option>Wedding</option>
          <option>Event</option>
          <option>Corporate / headshots</option>
          <option>Something else</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-xs uppercase tracking-[0.18em] text-stone-500">Message</label>
        <textarea
          id="message"
          name="message"
          rows="6"
          required
          class="mt-2 block w-full resize-y border-0 border-b border-stone-300 bg-transparent px-0 py-2 text-stone-900 placeholder-stone-400 focus:border-stone-900 focus:outline-none focus:ring-0"
        ></textarea>
      </div>

      <div class="pt-2">
        <button
          type="submit"
          class="border border-stone-900 bg-stone-900 px-8 py-3 text-[0.78rem] uppercase tracking-[0.2em] text-stone-50 transition-colors hover:bg-stone-50 hover:text-stone-900"
        >
          Send message
        </button>
      </div>
    </form>

    <div class="mt-16 border-t border-stone-200 pt-8 text-sm text-stone-500">
      <p>Prefer to skip the form?</p>
      <p class="mt-2">
        <a href={site.emailHref} class="text-stone-800 transition-colors hover:text-stone-900">
          {site.email}
        </a>
        <span class="mx-2 text-stone-300">·</span>
        <a href={site.phoneHref} class="text-stone-800 transition-colors hover:text-stone-900">
          {site.phone}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
