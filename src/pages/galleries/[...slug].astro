---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const galleries = await getCollection("galleries", ({ data }) => !data.draft);
  return galleries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateFmt = new Intl.DateTimeFormat("en-US", { month: "long", year: "numeric" });
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="mx-auto max-w-5xl px-6 pt-16 pb-24 sm:px-8 sm:pt-24 lg:px-12">
    <header class="mx-auto max-w-2xl text-center">
<h1 class="mt-4 font-display text-4xl font-light leading-tight text-stone-900 sm:text-5xl">
        {entry.data.title}
      </h1>
      {
        entry.data.description && (
          <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-stone-600 sm:text-lg">
            {entry.data.description}
          </p>
        )
      }
    </header>

    {/* Optional MDX/MD body */}
    <div class="prose prose-stone mx-auto mt-12 max-w-2xl">
      <Content />
    </div>

    <div class="mt-16 space-y-10 sm:space-y-14">
      {
        entry.data.images.map((img, i) => (
          <figure>
            <div class="overflow-hidden bg-stone-200">
              <img
                src={img.src}
                alt={img.alt}
                loading={i < 2 ? "eager" : "lazy"}
                decoding="async"
                class="h-auto w-full object-cover"
              />
            </div>
            {img.caption && (
              <figcaption class="mt-3 text-xs uppercase tracking-[0.18em] text-stone-400">
                {img.caption}
              </figcaption>
            )}
          </figure>
        ))
      }
    </div>

    <nav class="mt-24 border-t border-stone-200 pt-8 text-sm">
      <a
        href="/galleries"
        class="text-[0.78rem] uppercase tracking-[0.18em] text-stone-500 transition-colors hover:text-stone-900"
      >
        ← All galleries
      </a>
    </nav>
  </article>
</BaseLayout>
