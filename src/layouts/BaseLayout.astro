---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/inter";
import "../styles/global.css";

import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { site } from "../lib/site.ts";

interface Props {
  title?: string;
  description?: string;
  /** Use a tighter container for narrow text pages (about, contact). */
  narrow?: boolean;
}

const {
  title,
  description = "Portrait, family, event, and lifestyle photography by Aaron Thompson — based in Delco, serving the greater Philadelphia and Main Line area.",
  narrow = false,
} = Astro.props;

const fullTitle = title ? `${title} — ${site.name}` : site.name;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#faf8f4" />
  </head>
  <body class="flex min-h-screen flex-col bg-stone-50 text-stone-800 antialiased">
    <SiteHeader />
    <main class:list={["flex-1", narrow ? "" : ""]}>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
